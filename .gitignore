# Stack: Python 3 (stdlib core + web mirror; service/ deps live in a uv venv OUTSIDE the repo).

# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.vscode/
.idea/
*.swp

# Environment / secrets
.env
.env.local
.env.*.local

# Node / web
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Web verification evidence (screenshots, drivers, hashed evidence record)
.verify/

# Playwright MCP scratch output (a11y snapshots / console logs from the /verify-web-page
# perception loop; the durable verdict lives in .verify/perception.json, not here)
.playwright-mcp/

# Agent-service spend ledger (accumulated LLM cost; local state, never committed)
service/.spend.json

# Agent-service extraction cache (question -> routing; regenerates itself, local state)
service/.extraction-cache.json

# Instrumentation event log (requests, questions, client events, feedback). Local/volume state:
# it holds raw IPs and whatever visitors typed, so it is never committed. See service/feedback.py.
service/.feedback.jsonl

# Logs / cache / coverage
*.log
.cache/
coverage/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
